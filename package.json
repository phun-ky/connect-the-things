{
  "name": "connect-the-things",
  "version": "0.0.0",
  "description": "A helper to draw lines between things",
  "keywords": [
    "connect",
    "svg",
    "string",
    "line"
  ],
  "homepage": "https://github.com/phun-ky/connect-the-things#readme",
  "bugs": {
    "url": "https://github.com/phun-ky/connect-the-things/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phun-ky/connect-the-things.git"
  },
  "license": "MIT",
  "author": "Alexander Vassbotn Røyne-Helgesen <alexander@phun-ky.net>",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && vite build",
    "commit": "npx git-cz",
    "dev": "vite --force",
    "preview": "vite preview",
    "release": "release-it",
    "test": "glob -c \"node --import tsx --import global-jsdom/register --test --no-warnings\" \"./src/**/__tests__/**/*.spec.[jt]s\""
  },
  "dependencies": {
    "@phun-ky/angle": "^1.0.6",
    "@phun-ky/cardinal": "^3.0.3",
    "@phun-ky/typeof": "^3.0.4"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "eslint": "^10.5.0",
    "eslint-config-phun-ky": "^2.0.5",
    "git-cz": "^4.9.0",
    "globals": "^17.6.0",
    "prettier": "3.5.1",
    "release-it": "^20.2.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16"
  }
